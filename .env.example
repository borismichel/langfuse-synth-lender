# --- Langfuse target -----------------------------------------------------
# Copy to .env and fill in real keys. Point ONLY at a demo/sandbox project
# (the project name must contain `target.project_hint`, default "demo").
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# --- Model provider (optional) -------------------------------------------
# The seed path makes NO model calls, so this is NOT required for `synth seed`.
# Provide a REAL key to: create the managed LLM-as-judge evaluators
# (seed step 5b / `synth evaluators`), run `synth certify`, and the playground.
# Leave as the placeholder to skip the judges (the seed still completes).
ANTHROPIC_API_KEY=sk-ant-...
