# --- Langfuse (self-hosted) target ---------------------------------------
# Copy to .env and fill in. Point ONLY at a demo/sandbox project (see project_hint guardrail).
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# --- Model provider (only needed at demo time: `synth certify` / playground) ----
# The seed path makes NO model calls, so this is not required to `synth seed`.
ANTHROPIC_API_KEY=sk-ant-...
